Resistor = Module("@stdlib/generics/Resistor.zen")

P1 = Net()
P2 = Net()

Resistor(
    name="normal",
    value="1kohms",
    P1=P1,
    P2=P2,
)

Resistor(
    name="dnp",
    value="1kohms",
    P1=P1,
    P2=P2,
    dnp=True,
)

Resistor(
    name="exclude_from_bom",
    value="1kohms",
    P1=P1,
    P2=P2,
    skip_bom=True,
)

Resistor(
    name="exclude_from_bom_and_dnp",
    value="1kohms",
    P1=P1,
    P2=P2,
    skip_bom=True,
    dnp=True,
)

Layout(name="MyBoard", path="build/", bom_profile=None)
