_BOM_WARN_SUFFIX = ".\nTry using different component values or specify mpn directly (https://docs.pcb.new/pages/spec#match-component-match%2C-parts)"


def _no_match_warn(component_type, c, pkg=None, note=None):
    """Warn when no house part is found."""
    msg = "No house " + component_type + " found for " + c.value
    if pkg:
        msg += " " + pkg
    if note:
        msg += ". " + note
    warn(msg + _BOM_WARN_SUFFIX, kind="bom.match_generic")


