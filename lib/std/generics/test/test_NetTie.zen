"""Comprehensive test for NetTie component."""

load("../../interfaces.zen", "Net")
load("../../properties.zen", "Layout")

NetTie = Module("../NetTie.zen")

NetTie(
    name="NT_DEFAULT",
    P1=Net("NT_DEFAULT_P1"),
    P2=Net("NT_DEFAULT_P2"),
)

for variant in NetTie.Variant.values():
    name = "NT_" + str(variant)
    name = name.replace(".", "_")

    NetTie(
        name=name,
        variant=variant,
        **{"P{}".format(i + 1): Net(name + "_P{}".format(i + 1)) for i in range(int(variant[0]))},
    )
